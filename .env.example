# ═══════════════════════════════════════════
# AgenticSRE Environment Variables
# Copy to .env and fill in your values
# ═══════════════════════════════════════════

# ── LLM ──
DEEPSEEK_API_KEY=sk-your-api-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1   # Override in config.yaml

# ── Kubernetes ──
# SSH jump host for K8s access (default in config.yaml)
# K8S_SSH_JUMP=openstack@222.200.180.102
# K8S_SSH_TARGET=ubuntu@10.10.3.110

# ── Observability Stack ──
# PROMETHEUS_URL=http://localhost:9090
# ELASTICSEARCH_URL=http://localhost:9200
# JAEGER_URL=http://localhost:16686

# ── ChromaDB ──
# CHROMA_PERSIST_DIR=./data/chroma

# ── Web Dashboard ──
# WEB_PORT=8080
